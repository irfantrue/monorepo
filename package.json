{
    "name": "microservices",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "db:check": "turbo run db:check",
        "db:generate": "turbo run db:generate",
        "db:migrate": "turbo run db:migrate",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "turbo run format",
        "check-types": "turbo run check-types",
        "clean": "turbo run clean && rm -rf .turbo",
        "clean:deep": "rm -rf node_modules .turbo $(find apps packages -name 'node_modules' -type d 2>/dev/null) $(find apps packages -name '.turbo' -type d 2>/dev/null) $(find apps packages -name '.next' -type d 2>/dev/null) $(find apps packages -name 'dist' -type d 2>/dev/null)",
        "test": "turbo run test"
    },
    "dependencies": {
        "@vinejs/vine": "^4.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.0",
        "oxfmt": "^0.49.0",
        "oxlint": "^1.61.0",
        "turbo": "^2.9.6",
        "typescript": "6.0.3",
        "vitest": "^4.1.5"
    },
    "engines": {
        "bun": ">=1.0.0"
    },
    "packageManager": "bun@1.3.13"
}
