{
    "$schema": "https://json.schemastore.org/swcrc",
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "tsx": false,
            "dynamicImport": true
        },
        "target": "es2022",
        "loose": false,
        "externalHelpers": false,
        "preserveAllComments": false
    },
    "module": {
        "type": "es6"
    },
    "minify": true,
    "sourceMaps": true
}
