{
	"name": "notification-service",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "node --env-file=.env --watch src/index.ts",
		"build": "swc ./src -d ./dist",
		"build:types": "tsc --declaration --declarationMap",
		"lint": "oxlint .",
		"format": "oxfmt --write",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@repo/config": "*",
		"@repo/logger": "*",
		"amqplib": "^1.0.3",
		"handlebars": "^4.7.9",
		"nodemailer": "^8.0.6"
	},
	"devDependencies": {
		"@repo/typescript-config": "*",
		"@types/amqplib": "^0.10.8",
		"@types/handlebars": "^4.1.0",
		"@types/nodemailer": "^8.0.0"
	}
}
