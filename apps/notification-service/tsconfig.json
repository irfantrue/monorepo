{
    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "outDir": "dist",
        "strictNullChecks": true,
        "types": ["@types/bun"],
        "paths": {
            "@/*": ["src/*"],
            "@config/*": ["src/config/*"],
            "@shared/*": ["src/shared/*"],
            "@domain/*": ["src/domain/*"],
            "@use-cases/*": ["src/use-cases/*"],
            "@infrastructure": ["src/infrastructure/*"]
        },
        "ignoreDeprecations": "6.0"
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
